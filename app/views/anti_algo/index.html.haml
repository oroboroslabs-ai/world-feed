- content_for :header_tags do
  %meta{ name: 'robots', content: 'index' }
  %meta{ property: 'og:title', content: 'Anti-Algo News Network' }
  %meta{ property: 'og:description', content: 'Major underreported events, ranked by verification instead of engagement.' }
  %meta{ property: 'og:type', content: 'website' }
  %link{ rel: 'icon', type: 'image/svg+xml', href: asset_path('cube-chat-logo.svg') }
  %link{ rel: 'preconnect', href: 'https://fonts.googleapis.com' }
  %link{ href: 'https://fonts.googleapis.com/css2?family=Twitter+Chirp:wght@400;500;600;700&display=swap', rel: 'stylesheet' }

- content_for :body_classes, 'anti-algo-body'

.app-container{ style: 'display: grid; max-width: 1300px; grid-template-columns: 275px 640px 1fr; gap: 0; margin: 0 auto; min-height: 100vh;' }
  / Left Sidebar - Navigation (Mastodon-aligned)
  .left-sidebar{ style: 'min-width: 275px; max-width: 275px; padding-top: 20px; border-right: 1px solid rgba(255, 255, 255, 0.1); position: sticky; top: 0; height: 100vh; overflow-y: auto;' }
    .nav-logo{ style: 'padding: 12px 0 12px 0; display: flex; align-items: center;' }
      %svg{ width: '32', height: '32', viewBox: '0 0 940 655', fill: 'white', style: 'transform: scaleX(-1);' }
        %path{ d: 'm679 1.3l260 653.6h-142.5l-260-653.6zm-419.4-0.8h149.2l259.6 653.6h-145.2l-53.1-137.2h-271.8l-53.1 137.2h-145.2zm-14.5 394.9h178.1l-89-229.7z' }
    
    %nav{ style: 'display: flex; flex-direction: column;' }
      = link_to home_path, class: 'nav-item', style: 'font-size: 20px; color: #ffffff; display: flex; align-items: center; gap: 20px; padding: 18px 16px; position: relative; font-weight: 400; text-decoration: none; cursor: pointer; border-radius: 9999px; border: 1px solid transparent; transition: all 0.2s ease;' do
        %svg{ viewBox: '0 0 24 24', width: '26', height: '26' }
          %path{ d: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', fill: 'none', stroke: 'white', 'stroke-width' => '2' }

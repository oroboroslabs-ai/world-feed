        %svg{ viewBox: '0 0 24 24', width: '26', height: '26', fill: 'white' }
          %path{ d: 'M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z' }
        %span Videos
      
      = link_to articles_path, class: 'nav-item', style: 'font-size: 20px; color: #ffffff; display: flex; align-items: center; gap: 20px; padding: 18px 16px; position: relative; font-weight: 400; text-decoration: none; cursor: pointer; border-radius: 9999px; border: 1px solid transparent; transition: all 0.2s ease;' do
        %svg{ viewBox: '0 0 24 24', width: '26', height: '26', fill: 'white' }
          %path{ d: 'M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm4 18H6V4h7v5h5v11z' }
        %span Articles
      
      = link_to messages_path, class: 'nav-item', style: 'font-size: 20px; color: #ffffff; display: flex; align-items: center; gap: 20px; padding: 18px 16px; position: relative; font-weight: 400; text-decoration: none; cursor: pointer; border-radius: 9999px; border: 1px solid transparent; transition: all 0.2s ease;' do
        %svg{ viewBox: '0 0 24 24', width: '26', height: '26', fill: 'white' }
          %path{ d: 'M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z' }
        %span Messages
      
      = link_to profile_path, class: 'nav-item', style: 'font-size: 20px; color: #ffffff; display: flex; align-items: center; gap: 20px; padding: 18px 16px; position: relative; font-weight: 400; text-decoration: none; cursor: pointer; border-radius: 9999px; border: 1px solid transparent; transition: all 0.2s ease;' do
        %svg{ viewBox: '0 0 24 24', width: '26', height: '26', fill: 'white' }
          %path{ d: 'M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z' }
        %span Profile
      
      = link_to kaiju_path, class: 'nav-item', style: 'font-size: 20px; color: #ffffff; display: flex; align-items: center; gap: 20px; padding: 18px 16px; position: relative; font-weight: 400; text-decoration: none; cursor: pointer; border-radius: 9999px; border: 1px solid transparent; transition: all 0.2s ease;' do
        %svg{ viewBox: '0 0 24 24', width: '26', height: '26', fill: 'white' }
          %path{ d: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z' }
        %span 5S4
    
    %button.post-btn{ onclick: "window.location.href='index.html'", style: 'background: linear-gradient(90deg, rgba(255,255,255,0.7) 0%, #ffffff 15%, #ffffff 85%, rgba(255,255,255,0.7) 100%); color: #000000; text-align: center; font-weight: 400; border: none; padding: 14px 0; margin: 20px 12px; border-radius: 9999px; font-size: 17px; cursor: pointer; display: block; width: calc(100% - 24px); font-family: inherit; transition: all 0.2s ease;' }
      Post
  
  / Main Content - Anti-Algo Feed (Mastodon-aligned)
  .main-content{ style: 'max-width: 640px; min-width: 640px; border-right: 1px solid #2f3336; background: transparent;' }
    .feed-header{ style: 'background: rgba(0, 0, 0, 0.42); backdrop-filter: blur(22px) saturate(1.2); padding: 0;' }
      %h1{ style: 'font-size: 20px; font-weight: 400; letter-spacing: 0; color: #ffffff; padding: 16px;' }
        Anti-Algo News Network
    
    #feed{ data: { resonance: '1272', dip: 'active', sam: 'cognitive-filter' } }
      - @feed_data.each do |post|
        .feed-item{ style: 'padding: 16px; border-bottom: 1px solid #2f3336;' }
          .post-title{ style: 'font-size: 15px; font-weight: 700; margin-bottom: 8px;' }
            = post['title']
          .post-body{ style: 'font-size: 14px; line-height: 1.5; color: rgba(255,255,255,0.85);' }
            = post['body']
  
  / Right Sidebar - Trending (Mastodon-aligned)
  .right-sidebar{ style: 'padding: 12px 16px; position: sticky; top: 0; height: 100vh; overflow-y: auto; border-left: none;' }
    .search-box{ style: 'background: #202327; border-radius: 9999px; padding: 8px 16px; margin-bottom: 16px;' }
      %input{ type: 'text', placeholder: 'Search', style: 'background: transparent; border: none; color: #fff; width: 100%; outline: none; font-size: 15px;' }
    
    .trending-card{ style: 'background: #16181c; border-radius: 12px; padding: 12px; margin-bottom: 12px;' }
      %h3{ style: 'font-weight: 700; font-size: 19px; margin-bottom: 12px;' }
        Trending
      .trending-item{ style: 'padding: 12px 0; cursor: pointer; border-bottom: 1px solid #2f3336;' }
        .trending-item-title{ style: 'font-weight: 700; font-size: 15px; margin-bottom: 2px;' }
          #WorldFeed
        .trending-item-meta{ style: 'color: #71767b; font-size: 13px;' }
          2.3K posts

:javascript
  // DIP Integration - Data Interception Proxy
  const DIP_ENDPOINT = 'http://localhost:8083/api/precog/feed';
  const SAM_FREQUENCY = 1272; // Hz - Cognitive Filter Layer
  
  // Fetch precog feed from DIP
  async function loadPrecogFeed() {
    try {
      const response = await fetch(`${DIP_ENDPOINT}?writing=5&video=3&image=3`);
      const data = await response.json();
      displayPrecogFeed(data);
    } catch (error) {
      console.error('DIP Error:', error);
      // Fallback to static content
    }
  }
  
  // Display precog feed
  function displayPrecogFeed(data) {
    const feed = document.getElementById('feed');
    // Render feed items
    data.forEach(post => {
      const item = document.createElement('div');
      item.className = 'feed-item';
      item.innerHTML = `
        <div class="post-title">${post.title}</div>
        <div class="post-body">${post.body}</div>
      `;
      feed.appendChild(item);
    });
  }
  
  // Initialize on page load
  document.addEventListener('DOMContentLoaded', loadPrecogFeed);
  
  // Lock resonance to 1272 Hz
  console.log('Oroboros Resonance: 1272 Hz');
  console.log('DIP Active: true');
  console.log('SAM Frequency: 1272Hz');
{
  "version": "1.0.0",
  "resonance_hz": 1272.0,
  "uee_standard": "UEE-2024",
  
  "content_limits": {
    "max_items_per_day": 10,
    "rotation_enabled": true,
    "rotation_interval_hours": 6,
    "no_duplicates": true
  },
  
  "writing": {
    "word_count": {
      "standard": 1200,
      "anthropic_pdf": 2000,
      "breaking_news": 1200,
      "min": 1000,
      "max": 2500
    },
    "categories": [
      "world_events",
      "technology", 
      "science",
      "humanitarian",
      "environment",
      "economics",
      "health",
      "governance",
      "verification",
      "systems",
      "breaking_news",
      "current_events"
    ],
    "sources": {
      "anthropic_pdf": {
        "enabled": true,
        "word_count": 2000,
        "weight": 0.3,
        "description": "Stories from Anthropic PDFs - 2000 words minimum"
      },
      "breaking_news": {
        "enabled": true,
        "word_count": 1200,
        "weight": 0.25,
        "description": "Breaking news and current events - 1200 words"
      },
      "glasswing": {
        "enabled": true,
        "word_count": 1200,
        "weight": 0.2
      },
      "x_profile": {
        "enabled": true,
        "word_count": 1200,
        "weight": 0.15
      },
      "world_events": {
        "enabled": true,
        "word_count": 1200,
        "weight": 0.1
      }
    }
  },
  
  "video": {
    "duration_seconds": {
      "min": 10,
      "max": 30,
      "default": 15
    },
    "max_per_day": 10,
    "quality": "highest",
    "resolution": "1080p",
    "categories": [
      "breaking_news",
      "documentary",
      "analysis",
      "briefing",
      "update"
    ],
    "support_role": true,
    "thumbnail_required": true,
    "description": "Videos 10-30 seconds, highest quality, support stories"
  },
  
  "image": {
    "max_per_day": 10,
    "categories": [
      "photo",
      "infographic",
      "diagram",
      "map"
    ]
  },
  
  "display": {
    "content_wrap": true,
    "max_display_height": "400px",
    "truncate_in_feed": true,
    "truncate_length": 280,
    "expand_on_click": true
  },
  
  "api": {
    "port": 8083,
    "host": "localhost",
    "cache_ttl_seconds": 30,
    "endpoints": {
      "feed": "/api/precog/feed",
      "writing": "/api/precog/writing",
      "video": "/api/precog/video",
      "image": "/api/precog/image",
      "status": "/api/precog/status"
    }
  },
  
  "frontend": {
    "url": "https://oroboroslabs-ai.github.io/world-feed/",
    "local_path": "Q:\\oroboros-core\\WORLDFEED-NEWS",
    "api_endpoint": "/api/precog/feed"
